# Copy to .env and replace every secret before starting Docker.

# Public HTTP entry. Use ":80" for IP-only VPS access or "mail.example.com" for Caddy HTTPS.
APP_HOST=:80
HTTP_PORT=80
HTTPS_PORT=443

# Cloud Mail Worker runtime.
MAIL_DOMAIN=example.com
# Optional multi-domain JSON array, for example: ["example.com","example.org"]
MAIL_DOMAINS=
ADMIN_EMAIL=admin@example.com
JWT_SECRET=replace-with-a-long-random-string
CORS_ORIGIN=
ANALYSIS_CACHE=false
ORM_LOG=false

# SMTP API security. Generate with: openssl rand -hex 32
SMTP_API_TOKEN=replace-with-a-long-random-token
SMTP_API_ALLOWED_ORIGINS=

# SMTP provider settings.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_REJECT_UNAUTHORIZED=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=Cloud Mail

# API safety limits.
SMTP_RATE_LIMIT_MAX=60
SMTP_RATE_LIMIT_WINDOW_MS=60000
SMTP_MAX_BODY_BYTES=1048576
SMTP_MAX_RECIPIENTS=50
